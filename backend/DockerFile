# 1. Use an official Python image
FROM python:3.10

# 2. Set the working directory inside the container
WORKDIR /code

# 3. Copy your requirements file first
# Based on your screenshot, it's inside the app/ folder
COPY ./app/requirements.txt /code/requirements.txt

# 4. Install standard Python dependencies
RUN pip install --no-cache-dir --upgrade -r /code/requirements.txt

# 5. CRITICAL FOR PLAYWRIGHT: Install the Chromium browser and its system dependencies
RUN playwright install --with-deps chromium

# 6. Copy all your files into the container
COPY . /code

# 7. Expose the specific port Hugging Face requires
EXPOSE 7860

# 8. Command to run your application
CMD ["python", "run.py"]