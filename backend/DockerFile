# 1. Use the official Playwright image (This already contains all the complex Linux dependencies for Chrome!)
FROM mcr.microsoft.com/playwright/python:v1.40.0-jammy

# 2. Set the folder inside the server where our code will live
WORKDIR /app

# 3. Copy our requirements file first
COPY requirements.txt .

# 4. Install our Python packages
RUN pip install --no-cache-dir -r requirements.txt

# 5. Install the Chromium browser
RUN playwright install chromium

# 6. Copy the rest of our backend code into the server
COPY . .

# 7. Hugging Face requires apps to run on port 7860
EXPOSE 7860

# 8. The command to start your FastAPI server
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "7860"]